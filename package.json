{
  "name": "starter-vue",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.9.0",
  "description": "Opinionated Vite + Vue Starter Template using UnoCSS and shadcn-vue.",
  "homepage": "https://github.com/jinghaihan/starter-vue#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghaihan/starter-vue.git"
  },
  "bugs": "https://github.com/jinghaihan/starter-vue/issues",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest",
    "cn:add": "shadcn-vue add --",
    "cn:diff": "shadcn-vue diff --",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "npx simple-git-hooks",
    "taze": "taze -r --exclude pnpm",
    "taze:up": "taze major -I --exclude pnpm"
  },
  "dependencies": {
    "@unhead/vue": "^1.11.10",
    "@unocss/reset": "^0.63.4",
    "@vueuse/core": "^11.1.0",
    "class-variance-authority": "^0.7.0",
    "culori": "^4.0.1",
    "dayjs": "^1.11.13",
    "local-pkg": "^0.5.0",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "pinia": "^2.2.4",
    "pinia-plugin-persistedstate": "^4.1.1",
    "radix-vue": "^1.9.7",
    "simple-hue-picker": "^0.2.0",
    "tailwind-merge": "^2.5.4",
    "vaul-vue": "^0.2.0",
    "vue": "^3.5.12",
    "vue-i18n": "^10.0.4",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.8.0",
    "@iconify-json/lucide": "^1.2.10",
    "@iconify-json/radix-icons": "^1.2.1",
    "@intlify/unplugin-vue-i18n": "^5.2.0",
    "@types/culori": "^2.1.1",
    "@types/dom-view-transitions": "^1.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.7.7",
    "@types/nprogress": "^0.2.3",
    "@unocss/eslint-plugin": "^0.63.4",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.47",
    "postcss-nested": "^6.2.0",
    "shadcn-vue": "^0.11.0",
    "simple-git-hooks": "^2.11.1",
    "taze": "^0.17.2",
    "typescript": "^5.6.3",
    "unocss": "^0.63.4",
    "unocss-preset-animations": "^1.1.0",
    "unocss-preset-shadcn": "^0.3.1",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-vue-components": "^0.27.4",
    "unplugin-vue-router": "^0.10.8",
    "vite": "^5.4.9",
    "vitest": "^2.1.3",
    "vue-tsc": "^2.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
